# ============================================
# Brand Health Tracker - Environment Variables
# ============================================
# Copy this file to `.env` and fill in real values.
# NEVER commit the .env file to Git.

# Apify (https://console.apify.com → Settings → Integrations)
APIFY_TOKEN=your_apify_token_here
APIFY_USER_ID=your_apify_user_id_here

# Anthropic Claude API (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5

# Google Sheets (optional, for live dashboard - skip if using CSV only)
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google_service_account.json
GOOGLE_SHEETS_ID=your_google_sheet_id_here

# Output paths
OUTPUT_DIR=./output
RAW_DATA_PATH=./data/raw_mentions.csv
ENRICHED_DATA_PATH=./data/enriched_mentions.csv
REPORT_PATH=./output/weekly_report.pdf

# Pipeline config
BATCH_SIZE=20
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60

